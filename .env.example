# WhatsApp Cloud API Configurations
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_secret_token_for_webhook_validation

# WooCommerce API Configurations
WOOCOMMERCE_URL=https://your-store-url.com
WOOCOMMERCE_KEY=ck_your_woocommerce_consumer_key
WOOCOMMERCE_SECRET=cs_your_woocommerce_consumer_secret

# Supabase Configurations
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key

# AI / LLM Configs
# Choose between: openai, anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic configuration
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
